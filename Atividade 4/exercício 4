#include <stdio.h>

int main(){
    int números[15];
    int i;
 for (i = 0; i < 15; i++) {
 printf("Digite seu %dº número inteiro: ", (i + 1));
 scanf("%d", &números[i]);
 } 
 printf("\n--- NÚMEROS MAIORES OU IGUAIS A 10 ---\n");
 for (i = 0; i < 15; i++) {
    if(números[i] >= 10){
        printf("O %dº número = %d é maior ou igual a 10\n", (i + 1), números[i]);
    }
 }
 return 0;
}
