#include <stdio.h>

int main(){
    int números[10];
    int i;
 for (i = 0; i < 10; i++) {
 printf("Digite seu %dº número inteiro: ", (i + 1));
 scanf("%d", &números[i]);
 } 
 printf("\n--- NÚMEROS PARES ---\n");
 for (i = 0; i < 10; i++) {
    if(números[i] % 2 == 0) {
        printf("O %dº número = %d é par\n", (i + 1), números[i]);
    }
 }
 
 return 0;
}
