#include <stdio.h>

int main(){
    int números[20];
    int i;
    int soma = 0;

 for (i = 0; i < 20; i++) {
 printf("Digite seu %dº número inteiro: ", (i + 1));
 scanf("%d", &números[i]);
 } 
 printf("\n--- SOMA DOS 10 PRIMEIROS ---\n");
 for (i = 0; i <= 10; i++) {
    printf("Adicionando %d a soma \n", números[i]);
    soma = soma + números[i];
 }
 printf("A soma total = %d\n", soma);

 return 0;
}
