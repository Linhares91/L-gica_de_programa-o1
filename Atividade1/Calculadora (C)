#include <stdio.h>

int main() {
    double n1, n2, resultado;
    char operação;

    printf("digite dois números:\n");
    scanf("%lf %lf", &n1, &n2);

    printf("Digite a operação desejada (+, -, /, *): \n");
    scanf(" %c", &operação);

    switch(operação){
        case '+':
        resultado = n1 + n2;
        printf("%.2lf + %.2lf = %.2lf\n", n1, n2, resultado);
        break;
        case '-':
        resultado = n1 - n2;
        printf("%.2lf - %.2lf = %.2lf\n", n1, n2, resultado);
        break;
        case '*':
        resultado = n1 * n2;
        printf("%.2lf * %.2lf = %.2lf\n", n1, n2, resultado);
        break;
        case '/':
        if (n2 != 0.0) {
            resultado = n1 / n2;
        printf("%.2lf / %.2lf = %.2lf\n", n1, n2, resultado);
        } else {
            printf("Erro ! Não pode dividir por zero. \n");
        }
        break;
        default :
        printf("Operação inválida!\n");
    }

    return 0;

    }
